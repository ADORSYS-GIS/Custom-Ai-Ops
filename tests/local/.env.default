# ==============================================================================
# Configuration des tests locaux Custom-Ai-Ops
# ==============================================================================
# Copier ce fichier en .env et modifier selon votre environnement :
#   cp tests/local/.env.default tests/local/.env
# ==============================================================================

# URL du service Ollama (OpenAI-compatible)
OLLAMA_URL=http://localhost:11434

# Modèle Qwen à utiliser pour les tests
OLLAMA_MODEL=qwen2.5:1.5b

# Options
VERBOSE=false
