{
  "title": "llm-d: EPP Routing & KV-Cache Indexer",
  "uid": "llm-d-overview",
  "tags": ["llm-d", "epp", "kv-cache-indexer"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "panels": [
    {
      "id": 1,
      "title": "EPP Routing Decisions/s",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "sum(rate(epp_routing_decisions_total[5m]))",
          "legendFormat": "decisions/s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "thresholds": {
            "steps": [
              {"color": "red", "value": 0},
              {"color": "green", "value": 1}
            ]
          }
        }
      }
    },
    {
      "id": 2,
      "title": "EPP Cache Hit Rate",
      "type": "gauge",
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "sum(rate(epp_cache_hits_total[10m])) / sum(rate(epp_routing_decisions_total[10m]))"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "steps": [
              {"color": "red", "value": 0},
              {"color": "orange", "value": 0.3},
              {"color": "yellow", "value": 0.5},
              {"color": "green", "value": 0.7}
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "title": "EPP Routing Latency (p50/p95/p99)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(epp_routing_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(epp_routing_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(epp_routing_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p99"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "s"}}
    },
    {
      "id": 4,
      "title": "KV-Cache Indexer Status",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 4},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "up{job=\"llm-d-kv-cache-indexer\"}",
          "legendFormat": "indexer"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {"options": {"0": {"text": "DOWN", "color": "red"}, "1": {"text": "UP", "color": "green"}}, "type": "value"}
          ]
        }
      }
    },
    {
      "id": 5,
      "title": "KV-Cache Indexer Event Lag",
      "type": "timeseries",
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 4},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "llm_d_kv_indexer_event_lag_seconds",
          "legendFormat": "{{instance}}"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "s"}}
    },
    {
      "id": 6,
      "title": "InferencePool Ready vs Desired Replicas",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "llm_d_inference_pool_replicas_ready",
          "legendFormat": "ready {{pool_name}}"
        },
        {
          "expr": "llm_d_inference_pool_replicas_desired",
          "legendFormat": "desired {{pool_name}}"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "short"}}
    },
    {
      "id": 7,
      "title": "EPP Routing Errors/s",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "sum(rate(epp_routing_errors_total[5m]))",
          "legendFormat": "errors/s"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "ops"}}
    },
    {
      "id": 8,
      "title": "P/D KV-Transfer Rate",
      "type": "timeseries",
      "gridPos": {"h": 4, "w": 12, "x": 0, "y": 16},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "sum(rate(llm_d_kv_transfer_total[5m]))",
          "legendFormat": "transfers/s"
        },
        {
          "expr": "sum(rate(llm_d_kv_transfer_errors_total[5m]))",
          "legendFormat": "errors/s"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "ops"}}
    },
    {
      "id": 9,
      "title": "P/D KV-Transfer Latency (p95)",
      "type": "timeseries",
      "gridPos": {"h": 4, "w": 12, "x": 12, "y": 16},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(llm_d_kv_transfer_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "s"}}
    },
    {
      "id": 10,
      "title": "KV-Cache Indexer Memory Usage",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 20},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "container_memory_working_set_bytes{namespace=\"llm-d-system\",container=\"kv-cache-indexer\"}",
          "legendFormat": "{{pod}}"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "bytes"}}
    }
  ],
  "templating": {
    "list": []
  },
  "time": {"from": "now-1h", "to": "now"}
}